# K.I.R.O Register environment template.
# Copy this file to .env (for local docker-compose) or paste values directly
# in Dokploy's "Environment" tab. Never commit real credentials to git.
# NOTE: service.py loads .env automatically when present.

# -----------------------------------------------------------------------------
# Service mode
# -----------------------------------------------------------------------------
# Run mode; only one is needed. When left blank service runs one account and exits.
# SERVICE=true
# BATCH=5
# BATCH_LOOP=5
DELAY=300
BATCH_DELAY=3600
# HEADLESS=true
# VERBOSE=true

# -----------------------------------------------------------------------------
# Paths (override when not using default volumes)
# -----------------------------------------------------------------------------
# CONFIG_PATH=/config/kiro_config.json
# DOMAINS_PATH=/config/domains.txt
DB_PATH=/data/accounts.db
# APPDATA=/data

# -----------------------------------------------------------------------------
# Mail provider: gsuite_imap | shiromail | yydsmail
# -----------------------------------------------------------------------------
MAIL_PROVIDER=gsuite_imap

# GSuite/IMAP catch-all provider
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USER=user@gmail.com
IMAP_PASS=app_password
IMAP_FOLDER=INBOX
IMAP_DOMAINS_FILE=/config/domains.txt

# Easiest way to feed the domain pool from Dokploy:
# DOMAINS=example.com,example.net,example.org

# ShiroMail provider
SHIROMAIL_BASE_URL=https://shiromail.galiais.com
SHIROMAIL_API_KEY=
SHIROMAIL_DOMAIN_ID=

# YYDS Mail provider
YYDSMAIL_BASE_URL=
YYDSMAIL_API_KEY=
YYDSMAIL_DOMAIN=
YYDSMAIL_SUBDOMAIN=
YYDSMAIL_WILDCARD=false

# -----------------------------------------------------------------------------
# Captcha solver
# -----------------------------------------------------------------------------
CAPTCHA_PROVIDER=multibot
MULTIBOT_API_KEY=
YESCAPTCHA_API_KEY=

# -----------------------------------------------------------------------------
# 9router OAuth device-code flow
# -----------------------------------------------------------------------------
ROUTER9_URL=https://oapi.fastev.my.id
ROUTER9_PASSWORD=
ROUTER9_AUTH_TOKEN=
ROUTER9_AUTH_TOKEN_EXPIRES_AT=

# -----------------------------------------------------------------------------
# Optional proxy for all outgoing traffic
# -----------------------------------------------------------------------------
# PROXY_URL=http://user:pass@host:port
